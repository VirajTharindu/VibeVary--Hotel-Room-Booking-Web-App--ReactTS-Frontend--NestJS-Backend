# ---------------------------------------------
# VIBEVARY FRONTEND ENVIRONMENT CONFIGURATION
# ---------------------------------------------
# Copy this file to '.env' and fill in the values before running the React client.

# API Base URL (NestJS Backend)
VITE_API_URL=http://localhost:3000

# WebSocket Gateway URL (NestJS socket.io instance)
VITE_WS_URL=http://localhost:3000

# Feature Flags
VITE_ENABLE_MOCK_PAYMENTS=true
VITE_SHOW_ADMIN_DASHBOARD=false

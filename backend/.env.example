# ---------------------------------------------
# VIBEVARY BACKEND ENVIRONMENT CONFIGURATION
# ---------------------------------------------
# Copy this file to '.env' and fill in the values before running the application.

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# (Currently utilizing Local PouchDB instance, no remote connection string required for dev)
# FUTURE: POSTGRES_URL=postgresql://user:password@localhost:5432/vibevary

# WebSocket Configuration
CORS_ORIGIN=http://localhost:5174

# Security Secrets
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRATION=24h
